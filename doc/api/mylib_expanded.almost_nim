    for h`gensym1966 in gDeviceStatusChangedApiListenerHandles:
      DeviceStatusChanged.dropListener(ctx`gensym1966, h`gensym1966)
    gDeviceStatusChangedApiListenerHandles.setLen(0)
    return ok(RegisterEventListenerResult(handle: 0, success: true))
  else:
    return err("Unknown action: " & $action`gensym1966)

