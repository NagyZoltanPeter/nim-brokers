        AsyncChannel[Result[InitRequest, string]], 1))
    discard respChan[].open()
    var msg`gensym25 = InitRequestMtRequestMsg(isShutdown: false,
        requestKind: 1, configPath: configPath, responseChan: respChan)
    reqChan[].sendSync(msg`gensym25)
    let recvFut`gensym25 = respChan.recv()
    let completedRes`gensym25 = catch do:
      await withTimeout(recvFut`gensym25, gInitRequestMtRequestTimeout)
    if completedRes`gensym25.isErr():
