type
  InitRequestCResult* {.exportc.} = object
    error_message*: cstring
    configPath*: cstring
    initialized*: bool
proc encodeInitRequestToC(obj: InitRequest): InitRequestCResult =
  result.configPath = allocCStringCopy(obj.configPath)
  result.initialized = obj.initialized

proc free_init_request_result(r: ptr InitRequestCResult) {.
    exportc: "free_init_request_result", cdecl, dynlib.} =
  if r.isNil:
    return
  if not r.error_message.isNil:
    freeCString(r.error_message)
  if not r.configPath.isNil:
    freeCString(r.configPath)


# --- C-exported request function ---
proc init_request_request_with_args*(ctx: uint32; c_configPath: cstring): InitRequestCResult {.
    exportc: "init_request_request_with_args", cdecl, dynlib.} =
  let brokerCtx = BrokerContext(ctx)
  let nim_configPath = $c_configPath
  let res`gensym38 = waitFor request(InitRequest, brokerCtx, nim_configPath)
  if res`gensym38.isOk():
    return encodeInitRequestToC(res`gensym38.get())
  else:
    var errResult`gensym38: InitRequestCResult
    errResult`gensym38.error_message = allocCStringCopy(res`gensym38.error())
    return errResult`gensym38



