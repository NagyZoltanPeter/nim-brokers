            gDeviceStatusChangedApiListenerHandles[i`gensym1966])
        gDeviceStatusChangedApiListenerHandles.del(i`gensym1966)
        return ok(RegisterEventListenerResult(handle: targetId`gensym1966,
            success: true))
    return err("Handle not found")
