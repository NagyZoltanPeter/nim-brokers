## mylib_expanded.nim — Macro-expanded output of examples/ffiapi/nimlib/mylib.nim
## =================================================================================
## This file shows the actual Nim code generated by the FFI API macros:
##   ApiType, RequestBroker(API), EventBroker(API), registerBrokerLibrary
##
## Generated by compiling with -d:brokerDebug and extracting the repr output.
## The gensym suffixes (e.g. `gensym11) are normal Nim macro hygiene artifacts.
##
## NOT compilable — for documentation purposes only.
##
## Structure:
##   1. ApiType: DeviceInfo (shared struct for seq[T] results)
##   2. RequestBroker(API) × 6: InitRequest, DestroyRequest, AddDevice,
##      RemoveDevice, GetDevice, ListDevices
##      Each generates: MT broker infra + C result struct + encode/free + C export
##   3. EventBroker(API) × 2: DeviceStatusChanged, DeviceDiscovered
##      Each generates: MT event infra + C callback type + handler + on/off exports
##      First expansion also generates shared RegisterEventListenerResult broker
##   4. registerBrokerLibrary: "mylib"
##      Generates: initialize, init, shutdown, free_string, threads, event routing


# ===== ApiType: DeviceInfo =====
# Generates: Nim type + C-compatible CItem struct + encode proc
type
  DeviceInfo* = object
    deviceId*: int64
    name*: string
    deviceType*: string
    address*: string
    online*: bool
type
  DeviceInfoCItem* {.exportc.} = object
    deviceId*: int64
    name*: cstring
    deviceType*: cstring
    address*: cstring
    online*: bool
proc encodeDeviceInfoToCItem*(item: DeviceInfo): DeviceInfoCItem =
  result.deviceId = item.deviceId
  result.name = allocCStringCopy(item.name)
  result.deviceType = allocCStringCopy(item.deviceType)
  result.address = allocCStringCopy(item.address)
  result.online = item.online



